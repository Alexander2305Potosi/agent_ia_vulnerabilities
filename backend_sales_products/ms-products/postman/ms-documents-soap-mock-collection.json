          "mode": "raw",
          "raw": "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\"\n               xmlns:doc=\"http://example.com/documents\">\n    <soap:Header/>\n    <soap:Body>\n        <doc:UploadDocumentRequest>\n            <entityId>PROD-001</entityId>\n            <fileName>documento-especificaciones.pdf</fileName>\n            <fileSize>1048576</fileSize>\n            <fileExtension>pdf</fileExtension>\n            <content>JVBERi0xLjQK...</content>\n            <mimeType>application/pdf</mimeType>\n            <requestId>req-{{$randomUUID}}</requestId>\n            <timestamp>{{$isoTimestamp}}</timestamp>\n        </doc:UploadDocumentRequest>\n    </soap:Body>\n</soap:Envelope>"
        },
