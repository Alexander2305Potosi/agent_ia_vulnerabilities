<?xml version="1.0" encoding="UTF-8"?>
<con:soapui-project id="ms-products-soap-mock" activeEnvironment="Default"
    name="MS-Products SOAP Mock Service" resourceRoot="" soapui-version="5.7.2"
    abortOnError="false" runType="SEQUENTIAL"
    xmlns:con="http://eviware.com/soapui/config">

    <con:settings/>

    <!-- Interface definition -->
    <con:interface name="ProductServiceSoap" id="interface-1"
        definition="http://localhost:8081/ws/product?wsdl" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:type="con:WsdlInterface">

        <con:settings/>

        <!-- Operation: UploadDocument -->
        <con:operation name="UploadDocument" id="operation-1"
            bindingOperationName="UploadDocument" type="Request-Response"
            outputName="UploadDocumentResponse" inputName="UploadDocumentRequest"
            receivesAttachments="false" sendsAttachments="false"
            anonymous="optional">

            <con:settings/>

            <!-- Request definition -->
            <con:call name="Request 1" id="call-1">
                <con:settings/>
                <con:encoding>UTF-8</con:encoding>
                <con:endpoint>http://localhost:8081/ws/product</con:endpoint>
                <con:request><![CDATA[<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/" xmlns:doc="http://example.com/products">
    <soap:Header/>
    <soap:Body>
        <doc:UploadDocumentRequest>
            <doc:entityId>PROD-12345</doc:entityId>
            <doc:operation>UPLOAD_DOCUMENT</doc:operation>
            <doc:requestId>req-12345-abcde</doc:requestId>
            <doc:timestamp>2026-04-16T10:30:00Z</doc:timestamp>
            <doc:sourceSystem>ms-products</doc:sourceSystem>
            <doc:fileName>documento.pdf</doc:fileName>
            <doc:fileSize>1024</doc:fileSize>
            <doc:fileExtension>pdf</doc:fileExtension>
        </doc:UploadDocumentRequest>
    </soap:Body>
</soap:Envelope>]]></con:request>
                <con:wsaConfig mustUnderstand="NONE" version="200508"
                    action="http://example.com/products/UploadDocument"/>
            </con:call>
        </con:operation>
    </con:interface>

    <!-- Mock Service -->
    <con:mockService id="mock-service-1" port="8081" path="/ws/product"
        host="localhost" name="ProductServiceMock" docroot=""
        dispatch="SEQUENCE" dispatchXPath="" route="">

        <con:settings>
            <con:setting id="com.eviware.soapui.impl.wsdl.mock.WsdlMockService@create-response">true</con:setting>
        </con:settings>

        <con:properties/>

        <!-- Mock Operation Response: Success -->
        <con:mockOperation name="UploadDocument" id="mock-op-1"
            interface="interface-1" operation="UploadDocument">

            <con:settings/>

            <!-- Default Response: Success -->
            <con:mockResponse name="Success Response" id="mock-resp-1"
                encoding="UTF-8" httpStatus="200"
                contentType="text/xml; charset=utf-8"
                dispatchPath="// contains(., 'UPLOAD_DOCUMENT')">

                <con:settings/>
                <con:responseContent><![CDATA[<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/" xmlns:doc="http://example.com/products">
    <soap:Header/>
    <soap:Body>
        <doc:UploadDocumentResponse>
            <doc:success>true</doc:success>
            <doc:message>Document uploaded successfully</doc:message>
            <doc:documentId>DOC-${UUID}</doc:documentId>
            <doc:entityId>${requestBody//doc:entityId}</doc:entityId>
            <doc:fileName>${requestBody//doc:fileName}</doc:fileName>
            <doc:fileSize>${requestBody//doc:fileSize}</doc:fileSize>
            <doc:fileUrl>http://localhost:8081/files/${UUID}</doc:fileUrl>
            <doc:status>PROCESSED</doc:status>
            <doc:responseCode>200</doc:responseCode>
            <doc:processedAt>2026-04-16T10:30:01Z</doc:processedAt>
            <doc:processingTimeMs>150</doc:processingTimeMs>
            <doc:requestId>${requestBody//doc:requestId}</doc:requestId>
            <doc:sourceSystem>ms-products-mock</doc:sourceSystem>
        </doc:UploadDocumentResponse>
    </soap:Body>
</soap:Envelope>]]></con:responseContent>
                <con:wsaConfig mustUnderstand="NONE" version="200508"
                    action="http://example.com/products/UploadDocument"/>
            </con:mockResponse>

            <!-- Response: Query Success -->
            <con:mockResponse name="Query Success Response" id="mock-resp-2"
                encoding="UTF-8" httpStatus="200"
                contentType="text/xml; charset=utf-8"
                dispatchPath="// contains(., 'QUERY')">

                <con:settings/>
                <con:responseContent><![CDATA[<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/" xmlns:doc="http://example.com/products">
    <soap:Header/>
    <soap:Body>
        <doc:UploadDocumentResponse>
            <doc:success>true</doc:success>
            <doc:message>Entity query completed successfully</doc:message>
            <doc:documentId>DOC-QUERY-${#Project#requestCounter}</doc:documentId>
            <doc:entityId>${requestBody//doc:entityId}</doc:entityId>
            <doc:status>FOUND</doc:status>
            <doc:responseCode>200</doc:responseCode>
            <doc:processedAt>2026-04-16T10:30:01Z</doc:processedAt>
            <doc:processingTimeMs>50</doc:processingTimeMs>
            <doc:requestId>${requestBody//doc:requestId}</doc:requestId>
            <doc:sourceSystem>ms-products-mock</doc:sourceSystem>
        </doc:UploadDocumentResponse>
    </soap:Body>
</soap:Envelope>]]></con:responseContent>
                <con:wsaConfig mustUnderstand="NONE" version="200508"
                    action="http://example.com/products/UploadDocument"/>
            </con:mockResponse>

            <!-- Response: Error -->
            <con:mockResponse name="Error Response" id="mock-resp-3"
                encoding="UTF-8" httpStatus="500"
                contentType="text/xml; charset=utf-8">

                <con:settings/>
                <con:responseContent><![CDATA[<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/" xmlns:doc="http://example.com/products">
    <soap:Header/>
    <soap:Body>
        <soap:Fault>
            <faultcode>soap:Server</faultcode>
            <faultstring>Internal Server Error</faultstring>
            <detail>
                <doc:UploadDocumentResponse>
                    <doc:success>false</doc:success>
                    <doc:message>Error processing document upload</doc:message>
                    <doc:entityId>${requestBody//doc:entityId}</doc:entityId>
                    <doc:status>ERROR</doc:status>
                    <doc:responseCode>500</doc:responseCode>
                    <doc:errorCode>ERR-500</doc:errorCode>
                    <doc:errorMessage>Failed to process the upload request</doc:errorMessage>
                    <doc:requestId>${requestBody//doc:requestId}</doc:requestId>
                    <doc:sourceSystem>ms-products-mock</doc:sourceSystem>
                </doc:UploadDocumentResponse>
            </detail>
        </soap:Fault>
    </soap:Body>
</soap:Envelope>]]></con:responseContent>
                <con:wsaConfig mustUnderstand="NONE" version="200508"
                    action="http://example.com/products/UploadDocument"/>
            </con:mockResponse>

            <!-- Response: Validation Error -->
            <con:mockResponse name="Validation Error Response" id="mock-resp-4"
                encoding="UTF-8" httpStatus="400"
                contentType="text/xml; charset=utf-8">

                <con:settings/>
                <con:responseContent><![CDATA[<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/" xmlns:doc="http://example.com/products">
    <soap:Header/>
    <soap:Body>
        <soap:Fault>
            <faultcode>soap:Client</faultcode>
            <faultstring>Validation Error</faultstring>
            <detail>
                <doc:UploadDocumentResponse>
                    <doc:success>false</doc:success>
                    <doc:message>Invalid request parameters</doc:message>
                    <doc:status>VALIDATION_ERROR</doc:status>
                    <doc:responseCode>400</doc:responseCode>
                    <doc:errorCode>ERR-400</doc:errorCode>
                    <doc:errorMessage>Required fields missing: entityId or operation</doc:errorMessage>
                    <doc:requestId>${requestBody//doc:requestId}</doc:requestId>
                    <doc:sourceSystem>ms-products-mock</doc:sourceSystem>
                </doc:UploadDocumentResponse>
            </detail>
        </soap:Fault>
    </soap:Body>
</soap:Envelope>]]></con:responseContent>
                <con:wsaConfig mustUnderstand="NONE" version="200508"
                    action="http://example.com/products/UploadDocument"/>
            </con:mockResponse>

            <!-- Response: Timeout Simulation -->
            <con:mockResponse name="Timeout Response" id="mock-resp-5"
                encoding="UTF-8" httpStatus="504"
                contentType="text/xml; charset=utf-8"
                delay="11000">

                <con:settings/>
                <con:responseContent><![CDATA[<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/" xmlns:doc="http://example.com/products">
    <soap:Header/>
    <soap:Body>
        <soap:Fault>
            <faultcode>soap:Server</faultcode>
            <faultstring>Gateway Timeout</faultstring>
            <detail>
                <doc:UploadDocumentResponse>
                    <doc:success>false</doc:success>
                    <doc:message>Request processing timeout</doc:message>
                    <doc:status>TIMEOUT</doc:status>
                    <doc:responseCode>504</doc:responseCode>
                    <doc:errorCode>ERR-504</doc:errorCode>
                    <doc:errorMessage>The request timed out after 10 seconds</doc:errorMessage>
                    <doc:requestId>${requestBody//doc:requestId}</doc:requestId>
                    <doc:sourceSystem>ms-products-mock</doc:sourceSystem>
                </doc:UploadDocumentResponse>
            </detail>
        </soap:Fault>
    </soap:Body>
</soap:Envelope>]]></con:responseContent>
                <con:wsaConfig mustUnderstand="NONE" version="200508"
                    action="http://example.com/products/UploadDocument"/>
            </con:mockResponse>
        </con:mockOperation>
    </con:mockService>

    <!-- Test Cases -->
    <con:testSuite id="test-suite-1" name="SOAP Mock Test Suite">
        <con:settings/>
        <con:runType>SEQUENTIAL</con:runType>

        <!-- Test Case: Upload Document -->
        <con:testCase id="test-case-1" failOnError="true" failTestStepOnError="true"
            keepSession="false" name="Test Upload Document" searchProperties="true">
            <con:settings/>
            <con:testStep type="request" name="UploadDocument Request" id="test-step-1">
                <con:settings/>
                <con:config service="ProductServiceMock" interface="ProductServiceSoap"
                    operation="UploadDocument" path="/ws/product" action="http://example.com/products/UploadDocument">
                    <con:request><![CDATA[<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/" xmlns:doc="http://example.com/products">
    <soap:Header/>
    <soap:Body>
        <doc:UploadDocumentRequest>
            <doc:entityId>PROD-TEST-001</doc:entityId>
            <doc:operation>UPLOAD_DOCUMENT</doc:operation>
            <doc:requestId>req-test-001</doc:requestId>
            <doc:timestamp>2026-04-16T10:30:00Z</doc:timestamp>
            <doc:sourceSystem>ms-products</doc:sourceSystem>
            <doc:fileName>test-document.pdf</doc:fileName>
            <doc:fileSize>2048</doc:fileSize>
            <doc:fileExtension>pdf</doc:fileExtension>
        </doc:UploadDocumentRequest>
    </soap:Body>
</soap:Envelope>]]></con:request>
                    <con:assertion type="SOAP Response" id="assertion-1"/>
                    <con:assertion type="Valid HTTP Status Codes" id="assertion-2">
                        <con:configuration>
                            <codes>200</codes>
                        </con:configuration>
                    </con:assertion>
                    <con:assertion type="XPath Match" id="assertion-3">
                        <con:configuration>
                            <path>//doc:success</path>
                            <content>true</content>
                        </con:configuration>
                    </con:assertion>
                </con:config>
            </con:testStep>
        </con:testCase>

        <!-- Test Case: Query Entity -->
        <con:testCase id="test-case-2" failOnError="true" failTestStepOnError="true"
            keepSession="false" name="Test Query Entity" searchProperties="true">
            <con:settings/>
            <con:testStep type="request" name="Query Request" id="test-step-2">
                <con:settings/>
                <con:config service="ProductServiceMock" interface="ProductServiceSoap"
                    operation="UploadDocument" path="/ws/product" action="http://example.com/products/UploadDocument">
                    <con:request><![CDATA[<soap:Envelope xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/" xmlns:doc="http://example.com/products">
    <soap:Header/>
    <soap:Body>
        <doc:UploadDocumentRequest>
            <doc:entityId>PROD-QUERY-001</doc:entityId>
            <doc:operation>QUERY</doc:operation>
            <doc:requestId>req-query-001</doc:requestId>
            <doc:timestamp>2026-04-16T10:30:00Z</doc:timestamp>
            <doc:sourceSystem>ms-products</doc:sourceSystem>
        </doc:UploadDocumentRequest>
    </soap:Body>
</soap:Envelope>]]></con:request>
                </con:config>
            </con:testStep>
        </con:testCase>
    </con:testSuite>

    <!-- Properties -->
    <con:properties>
        <con:property>
            <con:name>soapEndpoint</con:name>
            <con:value>http://localhost:8081/ws/product</con:value>
        </con:property>
        <con:property>
            <con:name>mockPort</con:name>
            <con:value>8081</con:value>
        </con:property>
        <con:property>
            <con:name>requestCounter</con:name>
            <con:value>0</con:value>
        </con:property>
    </con:properties>

    <!-- Reporting -->
    <con:reporting/>

</con:soapui-project>